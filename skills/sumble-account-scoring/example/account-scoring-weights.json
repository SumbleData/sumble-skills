    "icp_persona_count_sales-development-representative": {
      "label": "SDR headcount",
      "column": "sales-development-representative_people",
      "category": "icp_persona_count",
      "transform": "log",
      "default_within": 20.82,
      "p99": 5.159055,
      "api_supported": true,
      "source": {
        "why": "SDR is a target persona \u2014 more SDRs = bigger ACV.",
        "kind": "sumble_api",
        "api": {
          "endpoint": "POST https://api.sumble.com/v6/organizations",
          "select_entity": {
            "type": "job_function",
            "term": "Sales Development Representative",
            "metrics": [
              "people_count"
            ]
          },
          "read": "people_count",
          "extract": "organizations[].entities[type='job_function',term='Sales Development Representative'].people_count"
        }
      },
      "sumble_link": {
        "path": "/people",
        "filters": {
          "job_function": [
            "Sales Development Representative"
          ]
        }
      }
    },
    "icp_persona_concentration_sales-development-representative": {
      "label": "SDR % of company",
      "column": "sales-development-representative_pct",
